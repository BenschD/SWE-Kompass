@startuml SWE_Kompass_Activity_PositionUpdate
skinparam monochrome true
skinparam shadowing false
start
:Eingang: onPositionUpdate(fix);
if (fix gueltig?\nWGS84, Zeit plausibel) then (nein)
  :werfe ValidationException;
  stop
else (ja)
endif
if (Segment-Luecke?) then (ja)
  :neues trkseg vormerken;
endif
if (Punktbudget?) then (Hard-Limit)
  :kontrollierter Stopp /\nEvent;
else (ok)
endif
:validierten Fix im\nRohspeicher ablegen;
:BearingCalculator:\nAzimut, Distanz, Ordinal;
:Listener benachrichtigen;
stop
@enduml
