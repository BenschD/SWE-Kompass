# =============================================================================
# Umgebungsvariablen — Vorlage (SWE-Kompass / Peilungskomponente)
# =============================================================================
# Verwendung:
#   1) Diese Datei nach ".env" kopieren (gleicher Ordner wie diese Datei = Repo-Root).
#   2) Werte eintragen. Datei ".env" wird nicht ins Git aufgenommen (.gitignore).
#
# Hinweis: Die Java-Bibliothek liest die meisten Variablen NICHT automatisch aus.
#          Ihr lest sie in eurer Host-App (z. B. mit System.getenv) und uebergebt
#          Werte an SessionFactory / W3wHttpClient / Konfiguration.
# =============================================================================

# --- What3Words (optional) ---
# API-Key von what3words.com — nur noetig, wenn ihr BearingBootstrap.w3wHttp(key, ...)
# bzw. einen W3wHttpClient mit echtem Netz verwendet.
# Im Code typisch: String key = System.getenv("W3W_API_KEY");
W3W_API_KEY=

# --- Maven (optional, fuer Skripte im Ordner implementation/) ---
# Voller Pfad zu mvn / mvn.cmd, falls "mvn" nicht im PATH liegt.
# Siehe implementation/run-all-capabilities.ps1 und run-all-capabilities.sh
MVN_CMD=

# --- JDK (optional) ---
# Pfad zum JDK; viele Tools (IDE, Maven) nutzen JAVA_HOME, falls gesetzt.
#JAVA_HOME=

# --- Maven JVM-Optionen (optional) ---
# Beispiel: mehr Heap fuer grosse Builds
#MAVEN_OPTS=-Xmx1024m

# --- SLF4J simple (optional, Laufzeit-Systemproperties) ---
# Wer slf4j-simple nutzt, kann Log-Level per -D setzen; Umgebung variiert je nach Shell.
# Beispiel unter Linux/macOS: export MAVEN_OPTS="-Dorg.slf4j.simpleLogger.defaultLogLevel=debug"
#ORG_SLF4J_SIMPLELOGGER_DEFAULT_LOGLEVEL=info

# --- CI / Entwicklung (optional) ---
# GitHub Actions Secrets werden im Repo unter Settings > Secrets gesetzt, nicht hier.
# Beispiel fuer eigene Pipelines: W3W_API_KEY als Repository-Secret.
