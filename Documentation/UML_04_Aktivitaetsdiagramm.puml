@startuml SWE-Kompass-Aktivitaetsdiagramm
!theme plain
skinparam backgroundColor #FEFEFE
skinparam activityBackgroundColor #F0F0F0
skinparam activityBorderColor #333333

start

:Peilung initialisieren\n(Position, Höhe, Azimuth);

if (Daten gültig?) then (ja)
    :Erstelle BearingSession;
    :Initialisiere GPXTrack;
else (nein)
    :Fehlermeldung;
    stop
endif

:GPS-Track gestartet;

repeat
    :Empfange neue Sensordaten\n(Position, Azimuth, Zeit);
    
    if (Daten plausibel?) then (ja)
        :Speichere GPS-Punkt im Track;
        :Aktualisiere Peilungsrichtung;
        :Gebe UpdateResult zurück;
    else (nein - ignorieren)
        :Validierungsfehler;
        :Fortsetzen;
    endif
    
    :Warte auf nächste Aktualisierung;

repeat while (Peilung aktiv?)

if (Peilung beendet?) then (regulär)
    :Finalisiere Session;
    :Wende Optimierung an:
    - Punkt-basiert (N-Intervall)
    - Distanz-basiert (X Meter)
    - Gerade-Optimierung;
    
    :Berechne Statistiken\n(Distanz, Punkte, Zeit);
    
    :Setze Status auf COMPLETED;
else (Abbruch)
    :Markiere Session als ABORTED;
    :Halte Daten in-Memory;
    :Gebe result mit Status ABORTED zurück;
endif

if (Nutzer will GPX exportieren?) then (ja)
    if (Als Datei?) then (ja)
        :Konvertiere zu GPX-XML;
        :Validiere GPX-Format;
        :Schreibe Datei (UTF-8);
        :Rückgabe: Dateipfad;
    else (als String)
        :Konvertiere zu GPX-XML;
        :Validiere GPX-Format;
        :Rückgabe: GPX-String;
    endif
else (nein - nur in-Memory)
    :Daten bleiben verfügbar;
endif

:Speichere optional W3W-Auflösung\n(Falls API verfügbar);

stop

@enduml
