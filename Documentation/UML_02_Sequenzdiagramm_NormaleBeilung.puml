@startuml SWE-Kompass-Sequenzdiagramm-NormaleBeilung
!theme plain
skinparam backgroundColor #FEFEFE
skinparam sequenceMessageAlign center

actor App as app
participant BearingComponent as component
participant BearingService as service
participant Validator as validator
participant GPXTrack as track
participant Repository as repo

app -> component: initiateBearing(position, azimuth)
    component -> validator: validate(position)
    validator --> component: valid ✓
    component -> service: createBearingSession()
    service -> track: new GPXTrack()
    service -> repo: save(session)
    service --> component: BearingSession
component --> app: session

app -> component: updateBearing(session, pos1, azimuth1)
    component -> validator: validate(pos1)
    validator --> component: valid ✓
    component -> service: recordGPSPoint(point1)
    service -> track: addPoint(point1)
    service --> component: UpdateResult
component --> app: pointsRecorded=1

app -> component: updateBearing(session, pos2, azimuth2)
    component -> validator: validate(pos2)
    validator --> component: valid ✓
    component -> service: recordGPSPoint(point2)
    service -> track: addPoint(point2)
    service --> component: UpdateResult
component --> app: pointsRecorded=2

app -> component: updateBearing(session, pos3, azimuth3)
    component -> validator: validate(pos3)
    validator --> component: valid ✓
    component -> service: recordGPSPoint(point3)
    service -> track: addPoint(point3)
    service --> component: UpdateResult
component --> app: pointsRecorded=3

app -> component: completeBearing(session)
    component -> service: optimizeTrack(track)
    service -> track: optimize()
    service --> component: optimizedTrack
    component -> service: compileBearingResult()
    service --> component: BearingResult
component --> app: result(3 points, optimized)

app -> component: exportToGPXString(result)
    component -> service: toGPXString(result)
    service --> component: "<?xml...><gpx>...</gpx>"
component --> app: gpxString

app -> component: saveGPXToFile(result, path)
    component -> service: writeGPXFile(path, gpxString)
    service --> component: saved ✓
component --> app: success

@enduml
